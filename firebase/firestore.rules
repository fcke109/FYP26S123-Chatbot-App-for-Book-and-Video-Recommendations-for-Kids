rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.planType == 'ADMIN';
    }

    function isParentOf(childId) {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.accountType == 'PARENT' &&
        childId in get(/databases/$(database)/documents/users/$(request.auth.uid)).data.childIds;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isParentOf(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin()
        || isParentOf(userId)
        || (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['childIds']));
      allow delete: if isAdmin();
    }

    // Invite codes
    match /inviteCodes/{code} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated();
    }

    // Chat history
    match /chatHistory/{userId}/conversations/{conversationId} {
      allow read: if isOwner(userId) || isParentOf(userId) || isAdmin();
      allow write: if isOwner(userId);

      match /messages/{messageId} {
        allow read: if isOwner(userId) || isParentOf(userId) || isAdmin();
        allow write: if isOwner(userId);
      }
    }

    // Favorites
    match /favorites/{userId}/items/{itemId} {
      allow read: if isOwner(userId) || isParentOf(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Reading history
    match /readingHistory/{userId}/sessions/{sessionId} {
      allow read: if isOwner(userId) || isParentOf(userId) || isAdmin();
      allow write: if isOwner(userId);
      allow delete: if isAdmin();
    }

    // Content library
    match /content/{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Curated books
    match /content_books/{bookId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
