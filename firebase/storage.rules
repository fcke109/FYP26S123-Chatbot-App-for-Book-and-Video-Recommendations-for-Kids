rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // User profile images
    match /users/{userId}/profile/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024  // 5MB limit
                   && request.resource.contentType.matches('image/.*');
    }

    // Content images (books and videos)
    match /content/{type}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false; // Only admins via admin SDK
    }

    // APK distribution — signed-in users only. The client uses the Storage SDK
    // (getBytes/getBlob), which goes through this rule on every fetch — so an
    // unauthenticated URL grab returns 403. Don't use getDownloadURL() for
    // these files; that issues a long-lived token URL that bypasses rules.
    match /apks/{fileName} {
      allow read: if request.auth != null;
      allow write: if false; // Upload via Firebase Console only
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
